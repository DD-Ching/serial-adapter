{
  "name": "serial-adapter",
  "version": "0.3.0",
  "description": "Serial device telemetry adapter plugin for OpenClaw",
  "license": "MIT",
  "author": "DD-Ching",
  "homepage": "https://github.com/DD-Ching/serial-adapter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DD-Ching/serial-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/DD-Ching/serial-adapter/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "serial",
    "telemetry",
    "arduino",
    "servo",
    "mpu6050"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "uv run pytest tests/ -x",
    "quick-check": "node scripts/quick_self_check.js",
    "postinstall": "node scripts/postinstall.mjs",
    "prepare": "node scripts/prepare.mjs",
    "prepack": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.39"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist/",
    "python/*.py",
    "scripts/",
    "openclaw.plugin.json",
    "pyproject.toml",
    "uv.lock",
    "README.md"
  ]
}
