{
  "name": "serial-adapter",
  "version": "0.3.4",
  "description": "Serial device telemetry adapter plugin for OpenClaw",
  "license": "MIT",
  "author": "DD-Ching",
  "homepage": "https://github.com/DD-Ching/serial-adapter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DD-Ching/serial-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/DD-Ching/serial-adapter/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "serial",
    "telemetry",
    "arduino",
    "servo",
    "mpu6050"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:algorithm-blocks": "npm --prefix plugins/algorithm_blocks_ts ci --no-audit --no-fund && npm --prefix plugins/algorithm_blocks_ts run build",
    "test": "uv run pytest tests/ -x",
    "quick-check": "node scripts/quick_self_check.js",
    "validate:repeatable": "powershell -ExecutionPolicy Bypass -File scripts/repeatable_validation.ps1",
    "preflight-runtime": "powershell -ExecutionPolicy Bypass -File scripts/preflight_runtime_guard.ps1",
    "self-verify": "powershell -ExecutionPolicy Bypass -File scripts/self_verify_gate.ps1",
    "postinstall": "node scripts/postinstall.mjs",
    "prepare": "node scripts/prepare.mjs",
    "prepack": "npm run build && npm run build:algorithm-blocks"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.39"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist/",
    "plugins/openclaw_ts_bridge/*.js",
    "plugins/openclaw_ts_bridge/*.json",
    "plugins/openclaw_ts_bridge/README.md",
    "plugins/algorithm_blocks_ts/dist/",
    "firmware/",
    "python/*.py",
    "scripts/*.js",
    "scripts/*.mjs",
    "scripts/*.ps1",
    "scripts/*.py",
    "openclaw.plugin.json",
    "pyproject.toml",
    "uv.lock",
    "README.md"
  ]
}
